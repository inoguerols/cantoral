# Copia este fichero a .env.local y rellena con los valores de TU proyecto Supabase.
# .env.local está en .gitignore: NUNCA se sube al repositorio.

# Públicas (van al navegador). La anon key es pública por diseño; la seguridad
# real la imponen las RLS policies de la base de datos, no el secreto de la clave.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# SECRETA: solo servidor (server actions). Salta toda RLS, así que NUNCA debe
# llevar el prefijo NEXT_PUBLIC_, ni llegar al cliente, ni subirse al repo.
# Defínela solo en .env.local y en las env vars del hosting (p.ej. Vercel).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta
